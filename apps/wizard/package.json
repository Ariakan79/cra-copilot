{
  "name": "@cra-copilot/wizard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen": "pnpm --filter @cra-copilot/rules-engine run gen",
    "dev": "pnpm run gen && vite",
    "build": "pnpm run gen && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "pnpm run gen && svelte-check --tsconfig ./tsconfig.json",
    "e2e": "pnpm run build && playwright test"
  },
  "dependencies": {
    "@cra-copilot/rules-engine": "workspace:*",
    "svelte": "^5.38.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^22.19.21",
    "svelte-check": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  }
}
